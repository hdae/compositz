{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Compositz",
  "version": "0.1.0",
  "identifier": "io.compositz.desktop",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../frontend/dist",
    "beforeDevCommand": { "script": "pnpm dev", "cwd": "../../frontend" },
    "beforeBuildCommand": { "script": "pnpm build", "cwd": "../../frontend" }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Compositz",
        "width": 1100,
        "height": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
