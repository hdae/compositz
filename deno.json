{
  "$comment": "Compositz workspace root. Requires Deno >= 2.9 (node:net named-pipe transport on Windows landed in 2.6.2; Deno Desktop APIs are 2.9). CI must pin the toolchain.",
  "workspace": [
    "./packages/core",
    "./packages/cli",
    "./packages/server",
    "./packages/desktop"
  ],
  "imports": {
    "@hono/hono": "jsr:@hono/hono@^4.12.27",
    "@std/fmt/colors": "jsr:@std/fmt@^1.0.3/colors",
    "@std/assert": "jsr:@std/assert@^1.0.8",
    "@std/tar": "jsr:@std/tar@^0.1.10",
    "@std/yaml": "jsr:@std/yaml@^1.1.1",
    "zod": "npm:zod@^4.4.3"
  },
  "tasks": {
    "doctor": "deno run -A --unstable-net packages/cli/main.ts doctor",
    "hello": "deno run -A --unstable-net packages/cli/main.ts hello",
    "cli": "deno run -A --unstable-net packages/cli/main.ts",
    "desktop": "deno desktop --backend cef -A --unstable-net -o dist/compositz-cef packages/desktop/main.ts",
    "desktop:webview": "deno desktop -A --unstable-net packages/desktop/main.ts",
    "serve": "deno run -A --unstable-net packages/server/main.ts",
    "schema": "deno run -A scripts/gen_schema.ts",
    "test": "deno test -A --unstable-net",
    "check": "deno check packages/core/mod.ts packages/cli/main.ts packages/server/main.ts packages/desktop/main.ts",
    "fmt": "deno fmt",
    "lint": "deno lint"
  },
  "fmt": {
    "lineWidth": 100,
    "semiColons": true
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ]
    }
  },
  "minimumDependencyAge": {
    "age": 1440,
    "exclude": []
  }
}
