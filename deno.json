{
  "$comment": "Compositz workspace root. Requires Deno >= 2.9 (node:net named-pipe transport on Windows landed in 2.6.2; Deno Desktop APIs are 2.9). CI must pin the toolchain.",
  "workspace": [
    "./packages/core",
    "./packages/cli",
    "./packages/desktop",
    "./packages/ui"
  ],
  "$comment_nodeModulesDir": "Required by the packages/ui Vite member (Fresh 2 needs a real node_modules). nodeModulesDir is a workspace-root-only setting, so it applies to every member; `auto` lets Deno auto-materialize the shared root node_modules (incl. transitive type deps like @types/node) for the pure-Deno packages without hand-listing them.",
  "nodeModulesDir": "auto",
  "imports": {
    "@std/fmt/colors": "jsr:@std/fmt@^1.0.3/colors",
    "@std/assert": "jsr:@std/assert@^1.0.8",
    "@std/tar": "jsr:@std/tar@^0.1.10",
    "@std/yaml": "jsr:@std/yaml@^1.1.1",
    "zod": "npm:zod@^4.4.3"
  },
  "tasks": {
    "doctor": "deno run -A --unstable-net packages/cli/main.ts doctor",
    "hello": "deno run -A --unstable-net packages/cli/main.ts hello",
    "cli": "deno run -A --unstable-net packages/cli/main.ts",
    "desktop": "deno desktop --backend cef -A --unstable-net -o dist/compositz-cef packages/desktop/main.ts",
    "desktop:webview": "deno desktop -A --unstable-net packages/desktop/main.ts",
    "ui": "deno task --cwd packages/ui dev",
    "ui:build": "deno task --cwd packages/ui build",
    "ui:check": "deno task --cwd packages/ui check",
    "schema": "deno run -A scripts/gen_schema.ts",
    "test": "deno test -A --unstable-net",
    "check": "deno check packages/core/mod.ts packages/cli/main.ts packages/desktop/main.ts",
    "fmt": "deno fmt",
    "lint": "deno lint"
  },
  "fmt": {
    "lineWidth": 100,
    "semiColons": true
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ]
    }
  },
  "minimumDependencyAge": {
    "age": 1440,
    "exclude": []
  }
}
