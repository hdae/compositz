{
  "$defs": {
    "BuildSpec": {
      "additionalProperties": false,
      "description": "Build the image from a Dockerfile context (mutually exclusive with `image`).",
      "properties": {
        "args": {
          "additionalProperties": {
            "type": "string"
          },
          "type": [
            "object",
            "null"
          ]
        },
        "dockerfile": {
          "default": "Dockerfile",
          "type": "string"
        }
      },
      "type": "object"
    },
    "CacheScope": {
      "enum": [
        "shared",
        "instance"
      ],
      "type": "string"
    },
    "CacheSpec": {
      "description": "Opt-in managed cache. Presets (`venv`, `huggingface`) inject well-known env\nvars; `custom` names its own volume + injected env var.",
      "oneOf": [
        {
          "description": "Per-instance uv venv + co-located uv cache/interpreters on one shared\nvolume (hardlink-safe). Injects `VIRTUAL_ENV` + `UV_PROJECT_ENVIRONMENT`\n(same path) + `UV_CACHE_DIR` + `UV_PYTHON_INSTALL_DIR`.",
          "properties": {
            "type": {
              "const": "venv",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "type": "object"
        },
        {
          "description": "Shared HuggingFace hub cache. Injects `HF_HOME`.",
          "properties": {
            "type": {
              "const": "huggingface",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "type": "object"
        },
        {
          "description": "A named cache injected into a chosen env var.",
          "properties": {
            "env": {
              "description": "Env var the mount path is injected into.",
              "type": "string"
            },
            "name": {
              "description": "Cache key (volume suffix).",
              "type": "string"
            },
            "scope": {
              "$ref": "#/$defs/CacheScope",
              "default": "shared",
              "description": "`shared` => one cache across apps; `instance` => a per-instance subpath."
            },
            "type": {
              "const": "custom",
              "type": "string"
            }
          },
          "required": [
            "type",
            "name",
            "env"
          ],
          "type": "object"
        }
      ]
    },
    "EnvSpec": {
      "additionalProperties": false,
      "properties": {
        "default": {
          "description": "Suggested/placeholder value (coexists with `required`).",
          "type": [
            "string",
            "null"
          ]
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "type": "string"
        },
        "required": {
          "default": false,
          "description": "The user must confirm a value before launch.",
          "type": "boolean"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "GpuMode": {
      "description": "GPU policy: `required` fails without a GPU; `preferred` tries GPU then falls\nback to CPU; `none` never attaches one.",
      "enum": [
        "required",
        "preferred",
        "none"
      ],
      "type": "string"
    },
    "MountMapping": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "description": "Stable key — host subdir / volume suffix.",
          "type": "string"
        },
        "placement": {
          "$ref": "#/$defs/Placement",
          "default": "volume"
        },
        "target": {
          "description": "In-container mount path (absolute).",
          "type": "string"
        }
      },
      "required": [
        "name",
        "target"
      ],
      "type": "object"
    },
    "Placement": {
      "enum": [
        "bind",
        "volume"
      ],
      "type": "string"
    },
    "PortMapping": {
      "additionalProperties": false,
      "properties": {
        "container": {
          "description": "Port the app listens on inside the container.",
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "host": {
          "description": "Host port to publish on (default = container; auto-bumped on conflict).",
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "name": {
          "description": "Stable key — UI button label and per-install override key.",
          "type": "string"
        },
        "path": {
          "default": "/",
          "description": "UI path (absolute), used to build the open URL.",
          "type": "string"
        },
        "protocol": {
          "$ref": "#/$defs/Protocol",
          "default": "tcp"
        },
        "web": {
          "default": false,
          "description": "Serves a browser UI — renders an \"Open UI\" button. Multiple allowed.",
          "type": "boolean"
        }
      },
      "required": [
        "name",
        "container"
      ],
      "type": "object"
    },
    "Protocol": {
      "enum": [
        "tcp",
        "udp"
      ],
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "A parsed + validated recipe manifest. Construct only via [`parse_manifest`],\nwhich applies the cross-field refinements a plain deserialize can't.",
  "properties": {
    "build": {
      "anyOf": [
        {
          "$ref": "#/$defs/BuildSpec"
        },
        {
          "type": "null"
        }
      ]
    },
    "cache": {
      "default": [],
      "description": "Opt-in managed caches; paths injected as env vars.",
      "items": {
        "$ref": "#/$defs/CacheSpec"
      },
      "type": "array"
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "env": {
      "default": [],
      "items": {
        "$ref": "#/$defs/EnvSpec"
      },
      "type": "array"
    },
    "gpu": {
      "$ref": "#/$defs/GpuMode",
      "default": "preferred"
    },
    "id": {
      "description": "Key for image/container/data/labels.",
      "type": "string"
    },
    "image": {
      "description": "Prebuilt image reference (mutually exclusive with `build`).",
      "type": [
        "string",
        "null"
      ]
    },
    "manifestVersion": {
      "format": "uint32",
      "minimum": 0,
      "type": "integer"
    },
    "mounts": {
      "default": [],
      "description": "Persisted data. Declared => kept across restarts.",
      "items": {
        "$ref": "#/$defs/MountMapping"
      },
      "type": "array"
    },
    "name": {
      "type": "string"
    },
    "ports": {
      "default": [],
      "items": {
        "$ref": "#/$defs/PortMapping"
      },
      "type": "array"
    },
    "version": {
      "type": "string"
    }
  },
  "required": [
    "manifestVersion",
    "id",
    "name",
    "version"
  ],
  "title": "Compositz recipe manifest",
  "type": "object"
}
