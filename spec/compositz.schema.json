{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://compositz.dev/schema/compositz.schema.json",
  "type": "object",
  "properties": {
    "manifestVersion": {
      "type": "number",
      "const": 2
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{0,62}$",
      "description": "Key for image/container/data/labels."
    },
    "name": {
      "type": "string",
      "pattern": "\\S"
    },
    "version": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,127}$"
    },
    "description": {
      "type": "string"
    },
    "build": {
      "type": "object",
      "properties": {
        "dockerfile": {
          "default": "Dockerfile",
          "type": "string"
        },
        "args": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false,
      "description": "Build the image from a Dockerfile context (mutually exclusive with `image`)."
    },
    "image": {
      "description": "Prebuilt image reference (mutually exclusive with `build`).",
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/@-]*$"
    },
    "ports": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_-]{0,62}$",
            "description": "Stable key — UI button label and per-install override key."
          },
          "container": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535,
            "description": "Port the app listens on inside the container."
          },
          "host": {
            "description": "Host port to publish on (default = container; auto-bumped on conflict).",
            "type": "integer",
            "minimum": 1,
            "maximum": 65535
          },
          "protocol": {
            "default": "tcp",
            "type": "string",
            "enum": [
              "tcp",
              "udp"
            ]
          },
          "web": {
            "default": false,
            "description": "Serves a browser UI — renders an \"Open UI\" button. Multiple allowed.",
            "type": "boolean"
          },
          "path": {
            "default": "/",
            "description": "UI path (absolute), used to build the open URL.",
            "type": "string",
            "pattern": "^\\/"
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "container"
        ],
        "additionalProperties": false
      }
    },
    "mounts": {
      "default": [],
      "description": "Persisted data. Declared => kept across restarts.",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_-]{0,62}$",
            "description": "Stable key — host subdir / volume suffix."
          },
          "target": {
            "type": "string",
            "pattern": "^\\/",
            "description": "In-container mount path."
          },
          "placement": {
            "default": "volume",
            "description": "bind => host <data-root>/<instanceId>/<name> (browsable, slow on Windows); volume => managed named volume.",
            "type": "string",
            "enum": [
              "bind",
              "volume"
            ]
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "target"
        ],
        "additionalProperties": false
      }
    },
    "cache": {
      "default": [],
      "description": "Opt-in managed caches; paths injected as env vars.",
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "venv"
              }
            },
            "required": [
              "type"
            ],
            "additionalProperties": false,
            "description": "Per-instance uv venv + co-located uv cache on one volume (hardlink-safe). Injects VIRTUAL_ENV + UV_CACHE_DIR."
          },
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "huggingface"
              }
            },
            "required": [
              "type"
            ],
            "additionalProperties": false,
            "description": "Shared HuggingFace hub cache. Injects HF_HOME."
          },
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "custom"
              },
              "name": {
                "type": "string",
                "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_-]{0,62}$",
                "description": "Cache key (volume suffix)."
              },
              "env": {
                "type": "string",
                "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
                "description": "Env var the mount path is injected into."
              },
              "scope": {
                "default": "shared",
                "description": "shared => one cache across apps; instance => a per-instance subpath (instanceId encodes the app).",
                "type": "string",
                "enum": [
                  "shared",
                  "instance"
                ]
              }
            },
            "required": [
              "type",
              "name",
              "env"
            ],
            "additionalProperties": false
          }
        ]
      }
    },
    "env": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
          },
          "description": {
            "type": "string"
          },
          "required": {
            "default": false,
            "description": "The user must confirm a value before launch.",
            "type": "boolean"
          },
          "default": {
            "description": "Suggested/placeholder value (coexists with required).",
            "type": "string"
          }
        },
        "required": [
          "name"
        ],
        "additionalProperties": false
      }
    },
    "gpu": {
      "default": "preferred",
      "type": "string",
      "enum": [
        "required",
        "preferred",
        "none"
      ],
      "description": "GPU policy: required fails without a GPU; preferred tries GPU then falls back to CPU; none never attaches one."
    }
  },
  "required": [
    "manifestVersion",
    "id",
    "name",
    "version"
  ],
  "additionalProperties": false,
  "title": "Compositz recipe manifest"
}
