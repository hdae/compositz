{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://compositz.dev/schema/compositz.schema.json",
  "type": "object",
  "properties": {
    "manifestVersion": {
      "type": "number",
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{0,62}$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "build": {
      "default": {
        "dockerfile": "Dockerfile"
      },
      "type": "object",
      "properties": {
        "dockerfile": {
          "default": "Dockerfile",
          "type": "string"
        },
        "args": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "web": {
      "type": "object",
      "properties": {
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "description": "Container port serving the web UI."
        },
        "hostPort": {
          "description": "Host port to publish it on (default = port).",
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "path": {
          "default": "/",
          "type": "string"
        }
      },
      "required": [
        "port"
      ],
      "additionalProperties": false,
      "description": "The container's primary web UI."
    },
    "ports": {
      "default": [],
      "description": "Additional ports to publish (besides web).",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "container": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535
          },
          "host": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535
          },
          "protocol": {
            "default": "tcp",
            "type": "string",
            "enum": [
              "tcp",
              "udp"
            ]
          }
        },
        "required": [
          "container"
        ],
        "additionalProperties": false
      }
    },
    "env": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "="
      }
    },
    "volumes": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "name",
          "target"
        ],
        "additionalProperties": false
      }
    },
    "gpu": {
      "default": "preferred",
      "type": "string",
      "enum": [
        "required",
        "preferred",
        "none"
      ],
      "description": "GPU policy: required fails without a GPU; preferred tries GPU then falls back to CPU; none never attaches one."
    }
  },
  "required": [
    "manifestVersion",
    "id",
    "name",
    "version"
  ],
  "additionalProperties": false,
  "title": "Compositz recipe manifest"
}
